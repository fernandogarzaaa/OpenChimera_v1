# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Server Configuration
NODE_ENV=production
PORT=5000
BACKEND_PORT=5000
FRONTEND_PORT=5173
WS_PORT=5001

# URLs
API_URL=https://api.yourdomain.com/api
FRONTEND_URL=https://yourdomain.com
WS_URL=wss://api.yourdomain.com

# JWT Configuration (REQUIRED - Generate secure random strings)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_64_BYTES
JWT_EXPIRES_IN=24h

# Encryption Configuration (REQUIRED)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_32_BYTES

# MongoDB Configuration
MONGO_USER=admin
MONGO_ கரைச_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MONGO_PORT=27017
MONGODB_URI=mongodb://admin:REPLACE_WITH_STRONG_PASSWORD@mongodb:27017/appforge?authSource=admin

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_PASSWORD@redis:6379

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Logging
LOG_LEVEL=info

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# Email Configuration (Optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Stripe (Optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Vercel Serverless LLM Gateway (for /api/base44/llm and /api/embeddings)
# Uses OpenAI-compatible API format
APPFORGE_LLM_BASE_URL=https://llm.appforge.io/v1
# APPFORGE_LLM_API_KEY: REQUIRED. Obtain this secret key from the AppForge provider dashboard.
APPFORGE_LLM_API_KEY=
APPFORGE_LLM_MODEL=chimera-auto
APPFORGE_EMBEDDING_MODEL=text-embedding-3-small

# Optional server route protection for /api/command, /api/factory/start, /api/telemetry
APPFORGE_API_KEY=