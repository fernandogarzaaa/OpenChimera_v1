# OPENCLAW & APPFORGE - ENVIRONMENT CONFIGURATION
# Copy this file to .env and replace the values with your local setup.

# --- SYSTEM PATHS ---
# The absolute path to your OpenClaw installation
OPENCLAW_HOME="D:\openclaw"
# The absolute path to your AppForge repository
APPFORGE_HOME="D:\appforge-main"

# --- HARDWARE CONFIGURATION ---
# Target VRAM allocation for local LLMs (e.g., 28 for 6GB RTX 2060)
LLAMA_CPP_GPU_LAYERS=28
# Host and Port for the local CHIMERA LLM server
CHIMERA_HOST="0.0.0.0"
CHIMERA_PORT=7860

# --- USER IDENTIFIERS & DELIVERY ---
# Primary phone number for automated cron job alerts (Include country code)
ADMIN_PHONE_NUMBER="+12345678900"
# Admin user name
ADMIN_NAME="Admin"

# --- SECURITY & API KEYS ---
# Add your third-party API keys here (DO NOT COMMIT THIS FILE)
# HUGGINGFACE_API_KEY=""
# OPENROUTER_API_KEY=""
