# OpenChimera environment variable reference
# Copy this file to .env and adjust values for your setup.
# All variables are optional — the runtime has built-in defaults for everything.
#
# .env files are NOT loaded automatically. Set these in your shell,
# systemd unit, or Docker Compose env_file block.

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------

# Filesystem root of the OpenChimera workspace (default: working directory)
# OPENCHIMERA_ROOT=/opt/openchimera

# Bind address (default: 127.0.0.1 — loopback only)
OPENCHIMERA_HOST=127.0.0.1

# API port (default: 7870)
OPENCHIMERA_PORT=7870

# Explicit thread cap for the API worker pool (default: auto via CPU count)
# OPENCHIMERA_MAX_WORKERS=8

# Allow binding to a non-loopback address without auth tokens — lab use only
# OPENCHIMERA_ALLOW_INSECURE_BIND=0

# Set to "1" when running inside a container (adjusts path + health logic)
# OPENCHIMERA_CONTAINERIZED=0

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Bearer token required on all /api/* requests (leave empty to disable auth)
# OPENCHIMERA_API_TOKEN=change-me-before-network-exposure

# Bearer token required for admin-scoped endpoints (e.g. /api/admin/*)
# OPENCHIMERA_ADMIN_TOKEN=change-me-before-network-exposure

# The header name to look for the token (default: Authorization)
OPENCHIMERA_API_AUTH_HEADER=Authorization

# ---------------------------------------------------------------------------
# TLS
# ---------------------------------------------------------------------------

# Set to "1" to enable HTTPS
# OPENCHIMERA_TLS_ENABLED=0
# OPENCHIMERA_TLS_CERTFILE=/path/to/cert.pem
# OPENCHIMERA_TLS_KEYFILE=/path/to/key.pem
# OPENCHIMERA_TLS_KEY_PASSWORD=

# ---------------------------------------------------------------------------
# Runtime profile
# ---------------------------------------------------------------------------

# Path to the runtime profile JSON (default: config/runtime_profile.json
# merged with config/runtime_profile.local.json if present)
# OPENCHIMERA_RUNTIME_PROFILE=config/runtime_profile.local.json

# Override values from the runtime profile at startup
# OPENCHIMERA_RUNTIME_MODE=bootstrap-safe

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# OPENCHIMERA_LOG_LEVEL=INFO

# Enable structured JSON logging to a file
# OPENCHIMERA_STRUCTURED_LOG_ENABLED=0
# OPENCHIMERA_STRUCTURED_LOG_PATH=logs/openchimera.jsonl

# ---------------------------------------------------------------------------
# External model services
# ---------------------------------------------------------------------------

# Vision / multimodal model override
# OPENCHIMERA_VISION_MODEL=
# OPENCHIMERA_IMAGE_MODEL=
# OPENCHIMERA_OPENROUTER_VISION_MODEL=openrouter/google/gemini-flash-1.5

# Hugging Face token — enables gated model discovery and HF Inference API fallback
# HF_TOKEN=hf_...

# MiniMind reasoning engine (alternative to llama.cpp local models)
# OPENCHIMERA_MINIMIND_HOST=127.0.0.1
# OPENCHIMERA_MINIMIND_PORT=8998
# OPENCHIMERA_MINIMIND_PYTHON=python

# ---------------------------------------------------------------------------
# Rate limiting (Redis backend — without this, falls back to in-memory)
# ---------------------------------------------------------------------------

# Redis connection URL — when set, enables distributed rate limiting
# OPENCHIMERA_REDIS_URL=redis://127.0.0.1:6379/0

# Token bucket refill rate (calls per minute per API token)
# OPENCHIMERA_TOKEN_RATE_PER_MINUTE=60

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Path to the SQLite observability database (default: data/observability.db)
# OPENCHIMERA_OBSERVABILITY_DB=data/observability.db

# ---------------------------------------------------------------------------
# External integrations (optional — safe to leave unset)
# ---------------------------------------------------------------------------

# Override the auto-detected root for each optional external system.
# Defaults resolve to external/<name>/ relative to OPENCHIMERA_ROOT.
# These systems are optional; OpenChimera runs without them.
# AETHER_ROOT=external/aether
# WRAITH_ROOT=external/wraith
# EVO_ROOT=external/evo
# OPENCHIMERA_HARNESS_ROOT=external/upstream-harness-repo
# OPENCHIMERA_LEGACY_HARNESS_ROOT=external/legacy-workflow-snapshot
# OPENCHIMERA_LEGACY_ROOT=external/legacy-workspace