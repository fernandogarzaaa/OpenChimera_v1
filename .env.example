OPENCHIMERA_HOST=127.0.0.1
OPENCHIMERA_PORT=7870
OPENCHIMERA_API_AUTH_HEADER=Authorization

# Set these locally if you want protected API access.
OPENCHIMERA_API_TOKEN=replace-with-user-token
OPENCHIMERA_ADMIN_TOKEN=replace-with-admin-token

# Optional: point OpenChimera at a private machine-specific profile.
OPENCHIMERA_RUNTIME_PROFILE=config/runtime_profile.local.json

# Optional: override the MiniMind Python interpreter.
OPENCHIMERA_MINIMIND_PYTHON=python