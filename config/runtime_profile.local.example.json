  "local_runtime": {
    "context_length": 4096,
    "launcher": {
      "enabled": true,
      "auto_start": false,
      "shutdown_with_manager": false,
      "llama_server_path": "",
      "shared_args": [],
      "model_args": {}
    }
  }
